<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="350" prefWidth="350" spacing="15" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.ecochef.controller.FormularioAlimento">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Añadir nuevo alimento" />

    <TextField fx:id="txtNombre" promptText="Nombre del alimento" />

    <ComboBox fx:id="comboCategorias" prefWidth="350" promptText="Selecciona una categoría" />
    <TextField fx:id="txtCalorias" promptText="Calorías (número)" />

    <DatePicker fx:id="dateCaducidad" prefWidth="350" promptText="Fecha de caducidad" />

    <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10 0 0 0;">
        <Button onAction="#guardar" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 5 15 5 15;" text="Guardar" />
        <Button onAction="#cancelar" style="-fx-padding: 5 15 5 15;" text="Cancelar" />
    </HBox>
</VBox>
