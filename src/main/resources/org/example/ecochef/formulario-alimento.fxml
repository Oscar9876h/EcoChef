<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" prefWidth="350" prefHeight="350"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.ecochef.controller.FormularioAlimento">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Añadir nuevo alimento" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TextField fx:id="txtNombre" promptText="Nombre del alimento"/>

    <TextField fx:id="txtTipo" promptText="Tipo (ej. Fruta, Verdura)"/>

    <TextField fx:id="txtCalorias" promptText="Calorías (número)"/>

    <DatePicker fx:id="dateCaducidad" promptText="Fecha de caducidad" prefWidth="350"/>

    <HBox spacing="10" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
        <Button text="Guardar" onAction="#guardar" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 5 15 5 15;"/>
        <Button text="Cancelar" onAction="#cancelar" style="-fx-padding: 5 15 5 15;"/>
    </HBox>
</VBox>