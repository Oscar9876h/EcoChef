<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" spacing="0.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.ecochef.controller.MenuPrincipalController">

    <HBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #27ae60; -fx-padding: 15;">
        <children>
            <Button onAction="#mostrarDespensa" style="-fx-background-color: white; -fx-font-weight: bold;" text="🍎 DESPENSA" />
            <Button onAction="#mostrarCaducidad" style="-fx-background-color: white; -fx-font-weight: bold;" text="⏰ CADUCIDAD" />
            <Button onAction="#mostrarRecetas" style="-fx-background-color: white; -fx-font-weight: bold;" text="👨‍🍳 RECETAS" />
        </children>
    </HBox>

    <VBox fx:id="contenedorPrincipal" alignment="TOP_CENTER" spacing="15.0" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>

        <Label fx:id="tituloSeccion" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Mi Despensa" />

        <HBox alignment="CENTER_RIGHT" prefWidth="200.0">
            <children>
                <Button fx:id="btnAñadirAlimento" onAction="#abrirFormularioAñadir" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="+ Añadir Alimento" textAlignment="CENTER" textFill="WHITE" />
            </children>
            <VBox.margin>
                <Insets right="20.0" />
            </VBox.margin>
        </HBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <FlowPane fx:id="flowAlimentos" hgap="10.0" vgap="10.0" />
            </content>
        </ScrollPane>
    </VBox>
</VBox>
