<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" spacing="0.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.ecochef.controller.MenuPrincipalController">

    <HBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #27ae60; -fx-padding: 15;">
        <children>
            <Button onAction="#mostrarDespensa" style="-fx-background-color: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🍎 DESPENSA" />
            <Button onAction="#mostrarCaducidad" style="-fx-background-color: white; -fx-font-weight: bold; -fx-cursor: hand;" text="⏰ CADUCIDAD" />
            <Button onAction="#mostrarRecetas" style="-fx-background-color: white; -fx-font-weight: bold; -fx-cursor: hand;" text="👨‍🍳 RECETAS" />
        </children>
    </HBox>

    <VBox fx:id="contenedorPrincipal" alignment="TOP_CENTER" VBox.vgrow="ALWAYS" />

</VBox>