<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" spacing="0.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="org.example.ecochef.controller.MenuPrincipalController">

    <HBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #27ae60; -fx-padding: 15;">
        <children>
            <Button onAction="#mostrarDespensa" style="-fx-background-color: white; -fx-font-weight: bold;" text="🍎 DESPENSA" />
            <Button onAction="#mostrarCaducidad" style="-fx-background-color: white; -fx-font-weight: bold;" text="⏰ CADUCIDAD" />
            <Button onAction="#mostrarRecetas" style="-fx-background-color: white; -fx-font-weight: bold;" text="👨‍🍳 RECETAS" />
        </children>
    </HBox>

    <VBox fx:id="contenedorPrincipal" VBox.vgrow="ALWAYS" alignment="TOP_CENTER" spacing="15.0">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>

        <Label fx:id="tituloSeccion" text="Mi Despensa" style="-fx-font-size: 24px; -fx-font-weight: bold;" />

        <HBox alignment="CENTER_RIGHT" prefWidth="200.0">
            <children>
                <Button onAction="#abrirFormularioAñadir" text="+ Añadir Alimento"
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
            </children>
            <VBox.margin>
                <Insets right="20.0" />
            </VBox.margin>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
            <content>
                <FlowPane fx:id="flowAlimentos" hgap="10.0" vgap="10.0" />
            </content>
        </ScrollPane>
    </VBox>
</VBox>