<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="TOP_CENTER" spacing="15.0" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.ecochef.controller.RecetasController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Libro de Recetas" />
   <Label text="Recetas sugeridas" textFill="#7f8c8d">
      <font>
         <Font size="14.0" />
      </font>
   </Label>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
        <content>
            <FlowPane fx:id="flowRecetasContenedor" hgap="10.0" vgap="10.0" />
        </content>
    </ScrollPane>
   <FlowPane fx:id="flowRecetas" hgap="15.0" prefHeight="200.0" prefWidth="200.0" vgap="15.0" />
</VBox>
